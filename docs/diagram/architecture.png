t-300 text-[11px] leading-[13px]">docx</p></div></div></div></div></button></div></div></div></div><div class="flex flex-col items-end gap-1"><div data-user-message-bubble="true" class="group relative inline-flex gap-2 bg-bg-300 rounded-xl pl-2.5 py-2.5 break-words text-text-100 transition-all max-w-[75ch] flex-col !px-4 max-w-[85%]" style="opacity: 1; transform: none;"><div class="flex flex-row gap-2 relative"><div class="flex-1"><div data-testid="user-message" class="font-large !font-user-message grid grid-cols-1 gap-2 py-0.5 relative [&amp;_ul]:!space-y-0 [&amp;_ol]:!space-y-0 [&amp;_ul]:pl-8 [&amp;_ol]:pl-8" style="max-height: 200px; overflow: hidden; position: relative;"><p class="whitespace-pre-wrap break-words">i want to start doing this homework from scratch i have git installed on my computer and this as my messy codeimport java.util.ArrayList;
import java.util.List;
// Simple Item class
class Item {
    private String name;
    private double price;
    private int quantity;
    public Item(String name, double price, int quantity) {
        this.name = name;
        this.price = price;
        this.quantity = quantity;
    }
    public double getPrice() { return price; }
    public int getQuantity() { return quantity; }
    public String getName() { return name; }
}
// POORLY DESIGNED SHOPPING CART CLASS
// This class manages the cart items AND handles all discount calculation logic internally.
class ShoppingCart {
    private List&lt;Item&gt; items = new ArrayList&lt;&gt;();
    public void addItem(Item item) {
        items.add(item);
    }
    public List&lt;Item&gt; getItems() {
        return items;
    }
    /**
     * WARNING: This method is a ticking time bomb!
     * Whenever a new discount rule is introduced, we are forced to add more 'if-else' blocks here.
     * This directly violates the Open/Closed Principle (OCP).
     */
    public double calculateTotal(String discountType) {
        double total = 0;</p><p class="whitespace-pre-wrap break-words">        // Calculate the raw total of items in the cart
        for (Item item : items) {
            total += item.getPrice() * item.getQuantity();
        }
        // Hardcoded Discount Calculation Logic (This is the core issue!)
        if (discountType != null) {
            if (discountType.equalsIgnoreCase("WELCOME10")) {
                total = total * 0.90; // 10% welcome discount
            } 
            else if (discountType.equalsIgnoreCase("BLACKFRIDAY")) {
                total = total * 0.50; // 50% Black Friday discount
            } 
            else if (discountType.equalsIgnoreCase("OVER100_LIMIT")) {
                // Flat $20 discount for purchases over $100
                if (total &gt; 100) {
                    total = total - 20;
                }
            } 
            else if (discountType.equalsIgnoreCase("BUY_2_GET_1")) {
                // If a highly complex rule is added here, the cart logic becomes spaghetti.
                if (items.size() &gt;= 2) {
                    total -= 10; // Temporary dummy rule
                }
            }
            // WHEN A NEW DISCOUNT RULE IS ADDED TOMORROW: 
            // You must modify this class, append another 'else if', 
            // and risk breaking existing discount calculations!
        }
        return total;
    }
}
// Main class to run and test the messy code
public class Main {
    public static void main(String[] args) {
        ShoppingCart cart = new ShoppingCart();
        cart.addItem(new Item("Wireless Mouse", 150.0, 1));
        cart.addItem(new Item("Mechanical Keyboard", 350.0, 1));
        // Raw total: 150 + 350 = 500
        System.out.println("Total without discount: $" + cart.calculateTotal(null));
        // WELCOME10 Applied (10% Off -&gt; 450)
        System.out.println("WELCOME10 Applied: $" + cart.calculateTotal("WELCOME10"));
        // BLACKFRIDAY Applied (50% Off -&gt; 250)
        System.out.println("BLACKFRIDAY Applied: $" + cart.calculateTotal("BLACKFRIDAY"));
        // OVER100_LIMIT Applied ($20 flat discount -&gt; 480)
        System.out.println("OVER100_LIMIT Applied: $" + cart.calculateTotal("OVER100_LIMIT"));
    }
} is it enough for messy code, im using java guide me from phase 0</p><div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-bg-300 to-transparent pointer-events-none"></div></div><button class="pb-3 pt-1 text-xs text-text-500/80 hover:text-text-100 transition w-3/4 text-left rounded-lg">Show more</button></div></div></div><div class="flex justify-start opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition" role="group" aria-label="Message actions"><div class="text-text-300"><div class="text-text-300 flex items-stretch justify-between"><span class="text-text-500 text-xs flex items-center mr-2" data-state="closed">3:01 PM</span><div class="flex items-center"><div class="w-fit" data-state="closed"><button class="inline-flex
